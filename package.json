{
  "name": "opencma",
  "version": "0.1.0",
  "description": "Open Cloud Managed Agents — Declaratively manage AI agent infrastructure",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "cma": "./bin/cma.ts"
  },
  "scripts": {
    "dev": "bun run bin/cma.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./bin/cma.ts --compile --outfile cma",
    "guard": "bun run scripts/guard.ts",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && bun run scripts/install-hooks.ts || true"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "jszip": "^3.10.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
